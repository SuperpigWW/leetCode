package assign05;

import static org.junit.jupiter.api.Assertions.*;

import org.junit.jupiter.api.Test;

/**
 * This class contains unit tests to check the correctness of the CalendarDateDemo class,
 * specifically the countDatesBefore method.
 * 
 * @author Haoquan Wang
 * @version 09.25.2025
 */
public class CalendarDateDemoTest {

    @Test
    public void testCountDatesBeforeNormalCase() {
        CalendarDate[] dates = {
            new CalendarDate(1, 15, 2020),
            new CalendarDate(3, 10, 2020),
            new CalendarDate(2, 5, 2020),
            new CalendarDate(4, 20, 2020)
        };
        CalendarDate target = new CalendarDate(3, 15, 2020);
        int result = CalendarDateDemo.countDatesBefore(dates, target);
        assertEquals(2, result, "Should correctly count dates before target in mixed array");
    }

    @Test
    public void testCountDatesBeforeAllDatesBeforeTarget() {
        CalendarDate[] dates = {
            new CalendarDate(1, 1, 2020),
            new CalendarDate(2, 1, 2020),
            new CalendarDate(3, 1, 2020)
        };
        CalendarDate target = new CalendarDate(12, 31, 2020);
        int result = CalendarDateDemo.countDatesBefore(dates, target);
        assertEquals(3, result, "Should count all dates when target is after all dates");
    }

    @Test
    public void testCountDatesBeforeNoDatesBeforeTarget() {
        CalendarDate[] dates = {
            new CalendarDate(6, 1, 2020),
            new CalendarDate(7, 1, 2020),
            new CalendarDate(8, 1, 2020)
        };
        CalendarDate target = new CalendarDate(1, 1, 2020);
        int result = CalendarDateDemo.countDatesBefore(dates, target);
        assertEquals(0, result, "Should return 0 when target is before all dates");
    }

    @Test
    public void testCountDatesBeforeEmptyArray() {
        CalendarDate[] dates = new CalendarDate[0];
        CalendarDate target = new CalendarDate(1, 1, 2020);
        int result = CalendarDateDemo.countDatesBefore(dates, target);
        assertEquals(0, result, "Should return 0 for empty array");
    }

    @Test
    public void testCountDatesBeforeSameDateAsTarget() {
        CalendarDate[] dates = {
            new CalendarDate(5, 10, 2020),
            new CalendarDate(5, 15, 2020),
            new CalendarDate(5, 20, 2020)
        };
        CalendarDate target = new CalendarDate(5, 15, 2020);
        int result = CalendarDateDemo.countDatesBefore(dates, target);
        assertEquals(1, result, "Should only count dates strictly before target (exclude equal dates)");
    }

    @Test
    public void testCountDatesBeforeDifferentYears() {
        CalendarDate[] dates = {
            new CalendarDate(12, 31, 2019),
            new CalendarDate(1, 1, 2020),
            new CalendarDate(1, 1, 2021)
        };
        CalendarDate target = new CalendarDate(1, 1, 2020);
        int result = CalendarDateDemo.countDatesBefore(dates, target);
        assertEquals(1, result, "Should correctly handle dates across different years");
    }

    @Test
    public void testCountDatesBeforeSingleElementArray() {
        CalendarDate[] dates = {
            new CalendarDate(6, 15, 2020)
        };
        CalendarDate target = new CalendarDate(7, 1, 2020);
        int result = CalendarDateDemo.countDatesBefore(dates, target);
        assertEquals(1, result, "Should correctly handle single element array");
    }

    @Test
    public void testCountDatesBeforeSameMonthDifferentDays() {
        CalendarDate[] dates = {
            new CalendarDate(5, 1, 2020),
            new CalendarDate(5, 15, 2020),
            new CalendarDate(5, 31, 2020)
        };
        CalendarDate target = new CalendarDate(5, 20, 2020);
        int result = CalendarDateDemo.countDatesBefore(dates, target);
        assertEquals(2, result, "Should correctly compare days within same month");
    }

    @Test
    public void testCountDatesBeforeNullArray() {
        CalendarDate[] dates = null;
        CalendarDate target = new CalendarDate(1, 1, 2020);
        int result = CalendarDateDemo.countDatesBefore(dates, target);
        assertEquals(0, result, "Should return 0 for null array");
    }

    @Test
    public void testCountDatesBeforeBoundaryYears() {
        CalendarDate[] dates = {
            new CalendarDate(1, 1, 1000),
            new CalendarDate(12, 31, 9999)
        };
        CalendarDate target = new CalendarDate(6, 1, 2020);
        int result = CalendarDateDemo.countDatesBefore(dates, target);
        assertEquals(1, result, "Should work correctly with year boundary values (1000 and 9999)");
    }
}
