package assign04;

import java.util.Scanner;

public class MethodPractice {

	public static int centimetersToInches(double cm) {
		int inches = (int) (cm / 2.54);
		return inches;
	}
	
	public static void shiftCipher(String initial, int shiftAmount) {
		for (int i = 0; i <= initial.length() - 1; i ++) {
        	if(initial.charAt(i) + shiftAmount > 126)
        		System.out.print((initial.charAt(i) + shiftAmount) - 127 + 32);
        	else
        	    System.out.print((char)(initial.charAt(i) + shiftAmount));                      
        }
		return initial;
	}
	
	public static int countPositive(Scanner input) {
		int count = 0;
		int loss;
		while (input.hasNext()) {
			if (input.hasNextInt()) {
				loss = input.nextInt();
				count += 1;
			}
			else
				input.next();
		}
		return count;
	}
	
	public static int totalInRange(int[] array, int start, int end) {
		int count = 0;
		if (-1 < start && start < end && end < array.length) {
			for (int i = start; i < end; i ++) {
				count += array[i];
			}
		}
		return count;
	}
	
	public static int[] generateEvenArray(int length) {
		int[] generate = new int[0];
		for (int i = 0; i < length; i ++) {
			generate[i] = 2 * i;
		}
		return generate;
	}
	
	public static int sumEven(int rangeEven) {
		return totalInRange(generateEvenArray(rangeEven / 2 + 1), 0, rangeEven / 2);
	}
	
	public static int logBaseTwo(int argument) {
		int logarithm = -1;
		while (argument > 0) {
			argument = argument / 2;
			logarithm += 1;
		}
		return logarithm;
	}
	
	public static void main(String[] args) {
		System.out.println("Checking shiftCipher(\"hello\", 3). Expecting a result of khoor. The actual result is " + shiftCipher("hello", 3) + ".");
		System.out.println("Checking countPositive(new Scanner(\"hello 0 10 2.2 string4 0.0\"). Expecting a result of 2. The actual result is " + countPositive(new Scanner("hello 0 10 2.2 string4 0.0")) + ".");

	}

}
