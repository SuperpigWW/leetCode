	public static int centimetersToInches(double cm) {
		int inches = (int) (cm / 2.54);
		return inches;
	}
	
	public static String shiftCipher(String initial, int shiftAmount) {
		for (int i = 0; i <= initial.length() - 1; i ++) {
        	if(initial.charAt(i) + shiftAmount > 126)
        	    System.out.print((char)((initial.charAt(i) + shiftAmount) - 127 + 32));
        	else
        	    System.out.print((char)(initial.charAt(i) + shiftAmount));                      
        }
		return initial;
	}
	
	public static countPositive(Scanner input) {
