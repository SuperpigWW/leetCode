	/**
	 * This method converts a double value in centimeters(positive) to the corresponding integer value in inches. 
	 * If the result in inches has a decimal part, it will be rounded down to the nearest whole number.
	 * @param a double value for the amount of centimeters(positive)
	 * @return the equivalent amount in inches and rounded down to the nearest inch, as type int
	 */
	public static int centimetersToInches(double cm) {
		int inches = (int) (cm / 2.54);
		return inches;
	}
	
	/**
	 * This method shifts the input String by the specified shift amount(positive) and outputs a new encrypted string
	 * @param the input String
	 * @param the shift amount(positive)
	 * @return the encrypted string after shifting
	 */
	public static String shiftCipher(String initial, int shiftAmount) {
		char[] change = new char[initial.length()];
		String generate;
		for (int i = 0; i <= initial.length() - 1; i ++) {
			int unicode = (int)(initial.charAt(i) + shiftAmount);
        	while (unicode > 126) {
        		unicode = unicode - 127 + 32;
        	}
        	change[i] = (char)(unicode);                      
        }
		generate = new String(change);
		return generate;
	}
	
	/**
	 * This method counts the number of int-type data in the user input
	 * @param the input of the user
	 * @return the number of int-type data in the user input
	 */
	public static int countPositive(Scanner input) {
		int count = 0;
		int loss;
		while (input.hasNext()) {
			if (input.hasNextInt()) {
				loss = input.nextInt();
				count += 1;
			}
			else
				input.next();
		}
		return count;
	}
	
	/**
	 * This method calculates the sum of elements in an int array between a start index (inclusive)                          
	 * and an end index (exclusive)
	 * It returns 0 if the index range is invalid
	 * @param an int array
	 * @param the start index (inclusive)
	 * @param the end index (exclusive)
	 * @return sum of elements in an int array between a start index (inclusive) and an end index (exclusive), 0 if the index range is invalid
	 */
	public static int totalInRange(int[] array, int start, int end) {
		int count = 0;
		if (-1 < start && start < end && end <= array.length) {
			for (int i = start; i < end; i ++) {
				count += array[i];
			}
		}
		return count;
	}
	
	/**
	 * This method creates an array of a specified length(positive), where the elements are evens starting from 0
	 * @param the length of the array(positive)
	 * @return an array starting from 0, where each element is the next even number, and the number of elements is equal to the input value
	 */
	public static int[] generateEvenArray(int length) {
		int[] generate = new int[length];
		for (int i = 0; i < length; i ++) {
			generate[i] = 2 * i;
		}
		return generate;
	}
	
	/**
	 * This method calculates the sum of all even numbers from 0 up to a given limit(inclusive)(positive)(even)
//	 * @param the upper limit of the summation range(inclusive)
	 * @return the sum of all even numbers from 0 up to a given limit
	 */
	public static int sumEven(int limit) {
		return totalInRange(generateEvenArray(limit / 2 + 1), 0, limit / 2) + generateEvenArray(limit / 2 + 1)[limit / 2];
	}
	
	/**
	 * This method calculates the integer value of the base-2 logarithm of the input value(positive), rounded down
	 * @param the int value(positive) to be taken the base-2 logarithm of
	 * @return the integer value obtained by taking the base-2 logarithm of the input value and rounding down the decimal part
	 */
	public static int logBaseTwo(int argument) {
		int logarithm = -1;
		while (argument > 0) {
			argument = argument / 2;
			logarithm += 1;
		}
		return logarithm;
	}
	
