	public static int centimetersToInches(double cm) {
		int inches = (int) (cm / 2.54);
		return inches;
	}
	
	public static String shiftCipher(String initial, int shiftAmount) {
		char[] change = new char[initial.length()];
		String generate;
		for (int i = 0; i <= initial.length() - 1; i ++) {
			int unicode = (int)(initial.charAt(i) + shiftAmount);
        	while (unicode > 126) {
        		unicode = unicode - 127 + 32;
        	}
        	change[i] = (char)(unicode);                      
        }
		generate = new String(change);
		return generate;
	}
	
	public static int countPositive(Scanner input) {
		int count = 0;
		int loss;
		while (input.hasNext()) {
			if (input.hasNextInt()) {
				loss = input.nextInt();
				count += 1;
			}
			else
				input.next();
		}
		return count;
	}
	
	public static int totalInRange(int[] array, int start, int end) {
		int count = 0;
		if (-1 < start && start < end && end < array.length) {
			for (int i = start; i < end; i ++) {
				count += array[i];
			}
		}
		return count;
	}
	
	public static int[] generateEvenArray(int length) {
		int[] generate = new int[length];
		for (int i = 0; i < length; i ++) {
			generate[i] = 2 * i;
		}
		return generate;
	}
	
	public static int sumEven(int rangeEven) {
		return totalInRange(generateEvenArray(rangeEven / 2 + 1), 0, rangeEven / 2);
	}
	
	public static int logBaseTwo(int argument) {
		int logarithm = -1;
		while (argument > 0) {
			argument = argument / 2;
			logarithm += 1;
		}
		return logarithm;
	}
	
