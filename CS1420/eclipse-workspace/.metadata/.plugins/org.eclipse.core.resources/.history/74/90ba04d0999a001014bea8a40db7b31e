package assign05;

/**
 * Represents a month with month number and provides utility methods for date calculations.
 * 
 * @author Haoquan Wang
 * @version 09.25.2025
 */
public class Month {
    
    private int monthNumber;
    
    /**
     * Constructs a Month object for January (month number 1).
     */
    public Month() {
        this.monthNumber = 1;
    }
    
    /**
     * Constructs a Month object with the specified month number.
     * 
     * @param monthNumber the month number (1-12)
     */
    public Month(int monthNumber) {
        this.monthNumber = monthNumber;
    }
    
    /**
     * Returns the month number.
     * 
     * @return the month number (1-12)
     */
    public int getMonthNumber() {
        return this.monthNumber;
    }
    
    /**
     * Returns the last day of the month considering leap years for February.
     * 
     * @param isLeapYear true if the year is a leap year, false otherwise
     * @return the last day of the month (28, 29, 30, or 31), or -1 for invalid month numbers
     */
    public int lastDay(boolean isLeapYear) {
        if (this.monthNumber == 1 || this.monthNumber == 3 || this.monthNumber == 5 || this.monthNumber == 7
                 || this.monthNumber == 8 || this.monthNumber == 10 || this.monthNumber == 12)
            return 31;
        else if (this.monthNumber == 4 || this.monthNumber == 6 || this.monthNumber == 9 || this.monthNumber == 11)
            return 30;
        else if (this.monthNumber == 2) {
            if (isLeapYear)
                return 29;
            else
                return 28;
        }
        else
            return -1;
    }
    
    /**
     * Checks if the given day is valid for this month considering leap years.
     * 
     * @param day the day to validate
     * @param isLeapYear true if the year is a leap year, false otherwise
     * @return true if the day is valid for this month, false otherwise
     */
    public boolean validDay(int day, boolean isLeapYear) {
        return day >= 1 && day <= this.lastDay(isLeapYear);
    }
    
    /**
     * Returns the name of the month.
     * 
     * @return the name of the month (e.g., "January", "February", etc.), or "Error" for invalid month numbers
     */
    public String toString() {
        String monthPrint;
        if (this.monthNumber == 1)
            monthPrint = "January";
        else if(this.monthNumber == 2)
            monthPrint = "February";
        else if(this.monthNumber == 3)
            monthPrint = "March";
        else if(this.monthNumber == 4)
            monthPrint = "April";
        else if(this.monthNumber == 5)
            monthPrint = "May";
        else if(this.monthNumber == 6)
            monthPrint = "June";
        else if(this.monthNumber == 7)
            monthPrint = "July";
        else if(this.monthNumber == 8)
            monthPrint = "August";
        else if(this.monthNumber == 9)
            monthPrint = "September";
        else if(this.monthNumber == 10)
            monthPrint = "October";
        else if(this.monthNumber == 11)
            monthPrint = "November";
        else if(this.monthNumber == 12)
            monthPrint = "December";
        else
            monthPrint = "Error";
        return monthPrint;
    }
    
    /**
     * Compares this month to the specified object for equality.
     * Two months are equal if they have the same month number.
     * 
     * @param other the object to compare with
     * @return true if the objects are equal, false otherwise
     */
    public boolean equals(Object other) {
        if (other == null) {
            return false;
        }
        if (!(other instanceof Month)) {
            return false;  
        }
        Month otherMonth = (Month) other;  
        return this.monthNumber == otherMonth.monthNumber;
    }
}